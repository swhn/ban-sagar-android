<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme used everywhere after the splash screen -->
    <style name="Theme.BanSagar" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!--
      Splash screen theme (core-splashscreen compat).
      Shows the speech-bubble icon on the brand dark background,
      then hands off to Theme.BanSagar once Compose is ready.
    -->
    <style name="Theme.BanSagar.Splash" parent="Theme.SplashScreen">
        <!-- Full-screen background: brand dark -->
        <item name="windowSplashScreenBackground">#06060B</item>
        <!-- Icon drawn on the splash circle -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <!-- Circle behind the icon: brand indigo -->
        <item name="windowSplashScreenIconBackgroundColor">#6366F1</item>
        <!-- Theme to apply after the splash exits -->
        <item name="postSplashScreenTheme">@style/Theme.BanSagar</item>
    </style>
</resources>
